# pnpm hoisting config for Expo web platform support
# react-native-web and react-dom need to be accessible from @expo/router-server
# which runs in Node.js context (not Metro) during SSR/static rendering.
# Without hoisting, Node.js resolution fails to find them from deep pnpm virtual store paths.
public-hoist-pattern[]=react-native-web
public-hoist-pattern[]=react-dom
