# pnpm hoisting config for Expo web platform support
# react-native-web and react-dom need to be accessible from @expo/router-server
# which runs in Node.js context (not Metro) during SSR/static rendering.
# Without hoisting, Node.js resolution fails to find them from deep pnpm virtual store paths.
public-hoist-pattern[]=react-native-web
public-hoist-pattern[]=react-dom

# pnpm hoisting config for Expo Metro runtime on native (iOS/Android)
# @expo/metro-runtime and related packages need to be resolvable from expo-router
# which is installed in a deep pnpm virtual store path.
public-hoist-pattern[]=@expo/metro-runtime
public-hoist-pattern[]=@expo/metro-runtime/*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=expo-*
public-hoist-pattern[]=metro
public-hoist-pattern[]=metro-*

# Babel preset Expo and its transform plugins need to be resolvable
# from the monorepo root for expo-router's EXPO_ROUTER_APP_ROOT injection to work.
# Without hoisting, babel-preset-expo silently skips the router transform plugin.
public-hoist-pattern[]=babel-preset-expo
public-hoist-pattern[]=babel-plugin-*
public-hoist-pattern[]=@babel/*