# =============================================================
# Resilio Plus — Environment Variables
# Copy to .env and fill in your values
# =============================================================

# Database
# Local dev: SQLite (default, no config needed)
# Production / Docker: PostgreSQL
DATABASE_URL=postgresql+psycopg2://resilio:resilio@localhost:5432/resilio_db

# JWT authentication secret (keep this secret in production)
JWT_SECRET=CHANGEME-use-a-long-random-string

# Anthropic API (required for coaching agents)
ANTHROPIC_API_KEY=CHANGEME

# Strava OAuth app credentials
STRAVA_CLIENT_ID=CHANGEME
STRAVA_CLIENT_SECRET=CHANGEME
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# Hevy Pro API key
HEVY_API_KEY=CHANGEME

# Terra API credentials (HRV / sleep data)
TERRA_API_KEY=CHANGEME
TERRA_DEV_ID=CHANGEME

# Food database API key (USDA / Open Food Facts)
FOOD_API_KEY=CHANGEME

# PostgreSQL (Docker Compose overrides — optional if using DATABASE_URL above)
POSTGRES_USER=resilio
POSTGRES_PASSWORD=resilio
POSTGRES_DB=resilio_db
