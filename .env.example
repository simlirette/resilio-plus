# Copy this file to .env and fill in real values before running docker compose.
# Never commit your .env file.

# --- PostgreSQL ---
POSTGRES_PASSWORD=changeme

# --- Backend ---
# Full DSN used by the backend (matches the postgres service above)
DATABASE_URL=postgresql://resilio:changeme@postgres:5432/resilio
# Secret key for JWT signing — use a long random string in production
JWT_SECRET=changeme-use-a-long-random-string

# --- Strava OAuth app ---
STRAVA_CLIENT_ID=CHANGEME
STRAVA_CLIENT_SECRET=CHANGEME
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# --- Hevy Pro API ---
HEVY_API_KEY=CHANGEME

# --- FatSecret OAuth2 ---
FATSECRET_CLIENT_ID=CHANGEME
FATSECRET_CLIENT_SECRET=CHANGEME

# --- Terra API (Apple Health gateway) ---
TERRA_API_KEY=CHANGEME
TERRA_DEV_ID=CHANGEME
