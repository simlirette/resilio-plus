    "@resilio/design-tokens": "workspace:*",
    "@resilio/shared-logic": "workspace:*",
    "@resilio/ui-mobile": "workspace:*",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
