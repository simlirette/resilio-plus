{
  "description": "Token Economy — Mapping des champs AthleteState autorisés par agent. Seul le Head Coach a accès au state complet. Chaque agent reçoit uniquement sa vue filtrée.",
  "head_coach": {
    "access": "full",
    "fields": ["*"],
    "note": "Accès complet — orchestre tous les agents"
  },
  "running_coach": {
    "access": "partial",
    "fields": [
      "athlete_id",
      "profile.name",
      "profile.age",
      "profile.sex",
      "profile.weight_kg",
      "profile.training_history.years_running",
      "profile.training_history.current_5k_time_min",
      "profile.training_history.current_10k_time_min",
      "profile.training_history.current_half_marathon_min",
      "profile.injuries_history",
      "profile.lifestyle.sleep_avg_hours",
      "running_profile",
      "fatigue.acwr",
      "fatigue.acwr_by_sport.running",
      "fatigue.hrv_rmssd_today",
      "fatigue.hrv_rmssd_baseline",
      "fatigue.recovery_score_today",
      "fatigue.weekly_fatigue_score",
      "fatigue.fatigue_by_muscle.quadriceps",
      "fatigue.fatigue_by_muscle.hamstrings",
      "fatigue.fatigue_by_muscle.calves",
      "fatigue.fatigue_by_muscle.glutes",
      "fatigue.sleep_hours_last_night",
      "compliance.last_4_weeks_completion_rate",
      "compliance.missed_sessions_this_week"
    ],
    "excluded_fields": [
      "lifting_profile",
      "swimming_profile",
      "biking_profile",
      "nutrition_profile",
      "fatigue.fatigue_by_muscle.chest",
      "fatigue.fatigue_by_muscle.back",
      "fatigue.fatigue_by_muscle.shoulders"
    ]
  },
