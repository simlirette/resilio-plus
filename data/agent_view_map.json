{
  "description": "Vues partielles d'AthleteState par agent — Token Economy",
  "source": "resilio-master-v2.md Section 2.3",
  "principle": "get_agent_view(athlete_state, agent_type) est la seule porte d'entrée. Les agents ne reçoivent jamais l'AthleteState brut.",
  "implementation_note": "Chaque clé correspond à un chemin dans l'AthleteState. Utiliser extract_fields(state, view) pour filtrer.",
  "views": {
    "head_coach": {
      "access": "FULL",
      "description": "Accès complet — seul agent avec autorité d'écriture",
      "fields": ["*"]
    },
    "running_coach": {
      "access": "PARTIAL",
      "description": "Profil course + fatigue pertinente + phase",
      "fields": [
        "profile.first_name",
        "profile.age",
        "profile.sex",
        "profile.weight_kg",
        "profile.height_cm",
        "profile.goals",
        "profile.injuries_history",
        "profile.equipment",
        "profile.available_days",
        "running_profile",
        "fatigue.acwr_by_sport.running",
        "fatigue.hrv_rmssd_today",
        "fatigue.hrv_rmssd_baseline",
        "fatigue.recovery_score_today",
        "fatigue.sleep_hours_last_night",
        "current_phase"
      ],
      "excluded": [
        "lifting_profile",
        "swimming_profile",
        "biking_profile",
        "nutrition_profile",
        "fatigue.fatigue_by_muscle",
        "fatigue.cns_load_7day_avg",
        "compliance"
      ]
    },
    "lifting_coach": {
      "access": "PARTIAL",
