{
  "name": "resilio-plus-monorepo",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @resilio/web dev",
    "dev:desktop": "concurrently -n \"next,tauri\" -c \"cyan,green\" \"pnpm dev:web\" \"wait-on tcp:3000 && pnpm --filter @resilio/desktop dev\"",
    "dev:mobile": "pnpm --filter @resilio/mobile dev",
    "dev:mobile:ios": "pnpm --filter @resilio/mobile ios",
    "build:web": "pnpm --filter @resilio/web build",
    "build:desktop": "pnpm --filter @resilio/web build:static && pnpm --filter @resilio/desktop build",
    "build:mobile": "pnpm --filter @resilio/mobile build",
    "build:mobile:ios": "pnpm --filter @resilio/mobile build:ios",
    "build:mobile:ios:preview": "cd apps/mobile && eas build --platform ios --profile preview",
    "build:mobile:ios:production": "cd apps/mobile && eas build --platform ios --profile production",
    "typecheck": "pnpm --filter @resilio/web typecheck",
    "typecheck:mobile": "cd apps/mobile && npx tsc --noEmit",
    "lint": "pnpm --filter @resilio/web lint",
    "test:mobile": "pnpm --filter @resilio/ui-mobile test",
    "test:mobile:watch": "pnpm --filter @resilio/ui-mobile test:watch",
    "test:mobile:regression": "pnpm --filter @resilio/mobile test:regression",
    "test:mobile:app": "pnpm --filter @resilio/mobile test:app",
    "preview:mobile-web": "pnpm --filter @resilio/mobile preview-web"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.28.2",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
